# 首次部署：复制此文件为 .env 后按需修改（cp .env.example .env）
# 不要提交 .env，其中可能含密码等敏感信息

# ---------- 当前站点（sz=深圳家 / hk=hkcloud / sgp=sgpcloud / dxb=迪拜家）----------
SITE=sz

# ---------- 部署路径（可选，默认使用项目根目录）----------
# 不设置则使用项目根目录（docker-compose.yml 所在目录）
# MOSDNS_DATA_DIR=.

# ---------- DNS 与 DoH 端口（可选，使用 network_mode: host，端口直接绑定宿主机）----------
# DNS 标准端口：默认 53（UDP/TCP），若被占用可改为其他端口（如 5353）
MOSDNS_LISTEN_PORT=53
# DoH 端口：默认 8443，作为额外服务（不影响标准 DNS 53 端口）
DOH_PORT=8443

# ---------- DoH 证书目录（可选，默认使用项目根目录下的 certs/）----------
# 不设置则使用 ${MOSDNS_DATA_DIR}/certs（默认 ./certs）
# DOH_CERT_DIR=./certs

# ---------- RouterOS API（updater 写入 address-list 用）----------
ROS_HOST=10.100.50.254
ROS_PORT=8728
ROS_USER=admin
ROS_PASS=请修改为实际密码
ROS_LIST=chatgpt-sgp
ROS_COMMENT=mosdns-chatgpt
ROS_AI_LIST=ai-sgp
ROS_AI_COMMENT=mosdns-ai
# AI 域名清单文件路径（容器内路径，通常无需修改）
AI_DOMAINS_FILE=/etc/mosdns/rules/ai-list.txt

# ---------- DNS（updater 解析域名时请求的 DNS）----------
# 使用公网 DNS，避免依赖本机 mosdns 是否已启动
DNS_SERVER=1.1.1.1
DNS_PORT=53

# ---------- address-list 超时与刷新间隔（秒）----------
TTL_SECONDS=1800
INTERVAL=120

# ---------- Updater 解析域名清单文件路径（容器内路径，通常无需修改）----------
# 默认值已在 docker-compose.yml 中设置，通常无需修改
DOMAINS_FILE=/etc/mosdns/rules/custom-remote.txt

# ---------- TLS 校验（可选，均有默认值）----------
# updater 在把 IP 写入 ROS 前，会先对每个 IP:443 做 TLS 握手，只写入能连通的，避免写进被墙/不可用 IP。
# TLS_VERIFY=0 可关闭校验，直接写入所有解析到的 IP（不推荐，可能写入不可用 IP）。
# 以下均可省略，用代码内默认即可。
TLS_VERIFY=1
TLS_PORT=443
TLS_TIMEOUT=2.5
TLS_CACHE_TTL=1800
TLS_VERIFY_HOST=

# ---------- 每日规则更新（可选）----------
# 每日 5:00 北京时间更新规则并重启 mosdns
# Docker Compose：需挂载 /var/run/docker.sock（compose 已配）
# RouterOS Container：需配置 /system/scheduler 在 5:05 执行 mosdns-restart 脚本，见 README
# MOSDNS_CONTAINER_NAME=mosdns

# ---------- 运行时（可选）----------
# 仅影响 Docker 内日志是否立即输出，不设亦可
PYTHONUNBUFFERED=1
