# 首次部署：复制此文件为 .env 后按需修改（cp .env.example .env）
# 不要提交 .env，其中可能含密码等敏感信息

# ---------- 当前站点（sz=深圳家 / hk=hkcloud / sgp=sgpcloud / dxb=迪拜家）----------
SITE=sz

# ---------- 站点间 DNS 配置（根据 SITE 自动选择需要的配置）----------
# sz（深圳）：需要 hkcloud_dns 和 sgpcloud_dns
# hk：只需要 sgpcloud_dns
# sgp：不需要（使用默认公网 DNS）
# dxb：需要 hkcloud_dns
HKCLOUD_DNS_IP=10.100.50.222
SGPCLOUD_DNS_IP=100.64.89.1

# ---------- DNS 与 DoH 端口（可选，使用 network_mode: host，端口直接绑定宿主机）----------
# DNS 标准端口：默认 53（UDP/TCP），若被占用可改为其他端口（如 5353）
MOSDNS_LISTEN_PORT=53
# DoH 端口：默认 8443，作为额外服务（不影响标准 DNS 53 端口）
DOH_PORT=8443

# ---------- DoH 证书（可选，证书不存在时不启用 DoH）----------
# 支持绝对路径或相对路径（相对路径相对于 MOSDNS_DATA_DIR）
# 支持 .pem、.crt、.key 等格式（PEM 格式）
# 示例：DOH_CERT=./certs/fullchain.pem 或 DOH_CERT=/etc/ssl/certs/cert.crt
# DOH_CERT=./certs/fullchain.pem
# DOH_KEY=./certs/privkey.pem

# ---------- RouterOS API（updater 写入 address-list 用）----------
ROS_HOST=10.100.50.254
ROS_PORT=8728
ROS_USER=admin
ROS_PASS=请修改为实际密码
ROS_LIST=chatgpt-sgp
ROS_COMMENT=mosdns-chatgpt
ROS_AI_LIST=ai-sgp
ROS_AI_COMMENT=mosdns-ai
# address-list 超时与刷新间隔（秒）
TTL_SECONDS=1800
INTERVAL=120

# ---------- DNS（updater 解析域名时请求的 DNS）----------
# 使用公网 DNS，避免依赖本机 mosdns 是否已启动
DNS_SERVER=1.1.1.1
DNS_PORT=53

# ---------- TLS 校验（可选，均有默认值）----------
# updater 在把 IP 写入 ROS 前，会先对每个 IP:443 做 TLS 握手，只写入能连通的，避免写进被墙/不可用 IP。
# TLS_VERIFY=0 可关闭校验，直接写入所有解析到的 IP（不推荐，可能写入不可用 IP）。
# 以下均可省略，用代码内默认即可。
TLS_VERIFY=1
TLS_PORT=443
TLS_TIMEOUT=2.5
TLS_CACHE_TTL=1800
TLS_VERIFY_HOST=

# ---------- 每日规则更新（可选）----------
# 时区：默认 Asia/Shanghai（北京时间）
TZ=Asia/Shanghai
# 每日更新时间：默认 5:00（格式：HH:MM，24小时制）
DAILY_UPDATE_TIME=05:00

# ---------- 运行时（可选）----------
# 仅影响 Docker 内日志是否立即输出，不设亦可
PYTHONUNBUFFERED=1
