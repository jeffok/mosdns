# mosdns 环境变量配置
# 复制为 .env 后按站点需求修改

# --- DNS 上游（逗号分隔，支持 IP:PORT 格式）---
DNS_CN=119.29.29.29,223.5.5.5,114.114.114.114
DNS_GLOBAL=1.1.1.1,8.8.8.8,9.9.9.9
# DNS_AI=10.100.89.3              # AI 上游，空则复用 DNS_GLOBAL

# --- DoH（不需要则保持注释）---
# DOH_ENABLED=1
# DOH_CERT=/etc/mosdns/certs/fullchain.pem
# DOH_KEY=/etc/mosdns/certs/privkey.pem

# --- 通用 ---
TZ=Asia/Shanghai
# RELOAD_DELAY=0                  # 04:30 重载前延迟秒数，多站点错开用

# --- 容器内部 DNS ---
# 指定容器内部下载规则/联网解析时使用的 DNS。
# 若留空，容器会自动取 DNS_GLOBAL 的第一个 IP。
# CONTAINER_DNS=8.8.8.8

# --- RouterOS ai-sgp 同步（不需要则保持注释）---
# ROS_HOST=192.168.88.254         # RouterOS LAN IP（REST API 走 HTTP 80，需启用 www 服务）
# ROS_USER=admin                  # RouterOS 用户名，默认 admin
# ROS_PASS=
# DNS_SERVER=                     # sync-ai 解析用 DNS，空则取 DNS_GLOBAL 第一个
# AI_LIST_URL=                    # 远端 AI 域名列表（默认 GitHub rules/ai-list.txt）
# RELOAD_ON_AI_LIST_CHANGE=1      # 远端 ai-list 变更后自动重载 mosdns（0/false 关闭）

# --- 仅 RouterOS Container 需要 ---
# CONTAINER_DNS=8.8.8.8
